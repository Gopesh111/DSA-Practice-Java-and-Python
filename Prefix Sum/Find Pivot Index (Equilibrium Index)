Given an array of integers, find the pivot index. The pivot index is the index where the sum of all the numbers strictly to the left is equal to the sum of all the numbers strictly to the right. If no such index exists, return -1.

Java:
class Solution {
    public int pivotIndex(int[] a) {
        int s=0,l=0;
        for(int x:a) s+=x;
        for(int i=0;i<a.length;i++){
            if(l==s-l-a[i]) return i;
            l+=a[i];
        }
        return -1;
    }
}

Python:
class Solution:
    def pivotIndex(self,a):
        s=sum(a)
        l=0
        for i in range(len(a)):
            if l==s-l-a[i]:
                return i
            l+=a[i]
        return -1
