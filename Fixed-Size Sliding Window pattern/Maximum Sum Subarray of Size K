Problem Statement: Given an array of integers and a number K, find the maximum sum of a contiguous subarray of size K.
(e.g., Array = [2, 1, 5, 1, 3, 2], K = 3. Output = 9, because [5, 1, 3] gives the max sum).

Java:
class Solution {
    public int maxSubarraySum(int[] arr, int k) {
        // Code here
        int n=arr.length;
        if(n<k)
        {
            return -1;
        }
       int window_sum=0;
        for(int i=0;i<k;i++)
        {
            window_sum+=arr[i];
        }
        int max_sum=window_sum;
        for(int i=k;i<n;i++)
        {
            window_sum=window_sum+arr[i]-arr[i-k];
            max_sum=Math.max(max_sum,window_sum);
        }
        return max_sum;
        
        
    }
}

Python:
class Solution:
    def maxSubarraySum(self, arr, k):
        # code here 
        n=len(arr)
        if n<k:
            return -1
        window_sum=0
        for i in range(0,k):
            window_sum+=arr[i]
        max_sum=window_sum
        for i in range(k,n):
            window_sum+=arr[i]-arr[i-k]
            max_sum=max(max_sum,window_sum)
        return max_sum
